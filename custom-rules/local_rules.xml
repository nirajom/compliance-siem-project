<!-- 
  Custom Compliance Rules for SIEM Monitoring Project
  Maps security events to PCI-DSS, ISO 27001, and NIST controls
  
  Location: /var/ossec/etc/rules/local_rules.xml
  After editing: sudo systemctl restart wazuh-manager
-->

<group name="local,syslog,iso27001,pci_dss,">

  <!-- Rule 100001: SSH Brute Force Detection -->
  <!-- Triggers when multiple SSH authentication failures occur -->
  <!-- Parent rule 5712: SSHD brute force attempt -->
  <rule id="100001" level="10">
    <if_sid>5712</if_sid>
    <description>ISO 27001 A.9.4.2 / PCI-DSS 10.2.4: Multiple failed SSH login attempts detected — possible brute force attack</description>
    <group>iso27001_A.9.4.2,pci_dss_10.2.4,authentication_failures,</group>
  </rule>

  <!-- Rule 100002: Privileged Account Access -->
  <!-- Triggers on attempts to access root or admin accounts -->
  <!-- Parent rule 5710: Attempt to login using a non-existent user -->
  <rule id="100002" level="12">
    <if_sid>5710</if_sid>
    <description>ISO 27001 A.9.2.3 / PCI-DSS 7.1: Privileged account access attempt — unauthorized user tried to authenticate</description>
    <group>iso27001_A.9.2.3,pci_dss_7.1,privileged_access,</group>
  </rule>

  <!-- Rule 100003: File Integrity Violation -->
  <!-- Triggers when critical system files are modified -->
  <!-- Parent rule 554: File added to the system -->
  <rule id="100003" level="10">
    <if_sid>554</if_sid>
    <description>ISO 27001 A.12.4.1 / PCI-DSS 11.5: Critical file modification detected — file integrity violation</description>
    <group>iso27001_A.12.4.1,pci_dss_11.5,file_integrity,</group>
  </rule>

  <!-- Rule 100004: Malware Detection -->
  <!-- Triggers on known malware signatures (e.g., EICAR test) -->
  <!-- Parent rule 87: System activity related to malware -->
  <rule id="100004" level="12">
    <if_sid>87</if_sid>
    <description>ISO 27001 A.12.2.1 / NIST SI-3 / PCI-DSS 5.1: Malware signature detected on endpoint</description>
    <group>iso27001_A.12.2.1,nist_SI-3,pci_dss_5.1,malware,</group>
  </rule>

  <!-- Rule 100005: Network Reconnaissance -->
  <!-- Triggers when port scanning activity is detected -->
  <!-- Parent rule 40101: Network scan detected -->
  <rule id="100005" level="8">
    <if_sid>40101</if_sid>
    <description>ISO 27001 A.13.1.1 / PCI-DSS 11.4: Network reconnaissance / port scan detected from external source</description>
    <group>iso27001_A.13.1.1,pci_dss_11.4,recon,network_scan,</group>
  </rule>

  <!-- Rule 100006: Unauthorized Privilege Escalation -->
  <!-- Triggers on unauthorized sudo command execution -->
  <!-- Parent rule 5402: Successful sudo to root -->
  <rule id="100006" level="10">
    <if_sid>5402</if_sid>
    <description>ISO 27001 A.9.2.6 / PCI-DSS 8.1.5: Unauthorized sudo command execution — privilege escalation attempt</description>
    <group>iso27001_A.9.2.6,pci_dss_8.1.5,privilege_escalation,</group>
  </rule>

</group>
